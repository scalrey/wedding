{
  "entities": {
    "RSVPEntry": {
      "title": "RSVPEntry",
      "description": "A representation of a guest's RSVP submission",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the guest"
        },
        "phone": {
          "type": "string",
          "description": "Mobile phone number of the guest, used as unique ID"
        },
        "attending": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Attendance status"
        },
        "guests": {
          "type": "number",
          "description": "Number of accompanying guests (0 to 10)"
        },
        "message": {
          "type": "string",
          "description": "Optional message to the couple"
        },
        "submittedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of creation"
        }
      },
      "required": ["name", "phone", "attending", "guests"]
    },
    "SiteConfig": {
      "title": "SiteConfig",
      "description": "Dynamic configuration of the wedding invitation page",
      "type": "object",
      "properties": {
        "names": {
          "type": "string"
        },
        "verse": {
          "type": "string"
        },
        "verseReference": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "receptionLocation": {
          "type": "string"
        },
        "ceremonyTime": {
          "type": "string"
        },
        "countdownTarget": {
          "type": "string",
          "format": "date-time"
        },
        "sections": {
          "type": "object"
        }
      },
      "required": ["names", "verse", "location", "ceremonyTime", "countdownTarget"]
    },
    "GalleryItem": {
      "title": "GalleryItem",
      "description": "A photo item shown in the gallery",
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "storagePath": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["url", "storagePath", "order"]
    }
  },
  "firestore": {
    "rsvps/{rsvpId}": {
      "schema": "RSVPEntry",
      "description": "Collection of wedding RSVP entries"
    },
    "site-config/{docId}": {
      "schema": "SiteConfig",
      "description": "Configuration document containing general metadata of the event"
    },
    "gallery/{itemId}": {
      "schema": "GalleryItem",
      "description": "Collection of photographic material and dynamic gallery image details"
    }
  }
}
